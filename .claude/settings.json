{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/lockdown-deny.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(coily:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git config --get:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)"
    ],
    "deny": [
      "Bash(aws:*)",
      "Bash(bash:*)",
      "Bash(brew:*)",
      "Bash(bun:*)",
      "Bash(bundle:*)",
      "Bash(cargo:*)",
      "Bash(cmd.exe:*)",
      "Bash(cmd:*)",
      "Bash(cscript.exe:*)",
      "Bash(cscript:*)",
      "Bash(dash:*)",
      "Bash(deno:*)",
      "Bash(docker:*)",
      "Bash(env:*)",
      "Bash(exec:*)",
      "Bash(fish:*)",
      "Bash(gcloud:*)",
      "Bash(gem:*)",
      "Bash(gh:*)",
      "Bash(git clean -fd:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(go run:*)",
      "Bash(helm:*)",
      "Bash(invoke:*)",
      "Bash(just:*)",
      "Bash(ksh:*)",
      "Bash(kubectl:*)",
      "Bash(make:*)",
      "Bash(mshta.exe:*)",
      "Bash(mshta:*)",
      "Bash(node:*)",
      "Bash(nox:*)",
      "Bash(npm:*)",
      "Bash(osascript:*)",
      "Bash(perl:*)",
      "Bash(pip:*)",
      "Bash(pipx:*)",
      "Bash(pnpm:*)",
      "Bash(poetry:*)",
      "Bash(powershell.exe:*)",
      "Bash(powershell:*)",
      "Bash(pwsh.exe:*)",
      "Bash(pwsh:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(regsvr32.exe:*)",
      "Bash(regsvr32:*)",
      "Bash(rsync:*)",
      "Bash(ruby:*)",
      "Bash(rundll32.exe:*)",
      "Bash(rundll32:*)",
      "Bash(scp:*)",
      "Bash(sh:*)",
      "Bash(ssh:*)",
      "Bash(sshfs:*)",
      "Bash(tailscale:*)",
      "Bash(task:*)",
      "Bash(terraform:*)",
      "Bash(tflint:*)",
      "Bash(tfsec:*)",
      "Bash(tox:*)",
      "Bash(uv:*)",
      "Bash(wscript.exe:*)",
      "Bash(wscript:*)",
      "Bash(xargs:*)",
      "Bash(yarn:*)",
      "Bash(zsh:*)",
      "PowerShell",
      "PowerShell(*)"
    ]
  }
}