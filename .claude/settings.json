{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/lockdown-deny.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(coily ops flyctl:*)",
      "Bash(coily:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git config --get:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(yq:*)"
    ],
    "deny": [
      "Bash(bash:*)",
      "Bash(cmd.exe:*)",
      "Bash(cmd:*)",
      "Bash(cscript.exe:*)",
      "Bash(cscript:*)",
      "Bash(dash:*)",
      "Bash(deno:*)",
      "Bash(env:*)",
      "Bash(exec:*)",
      "Bash(fish:*)",
      "Bash(flyctl:*)",
      "Bash(gcloud:*)",
      "Bash(git clean -fd:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(go run:*)",
      "Bash(helm:*)",
      "Bash(ksh:*)",
      "Bash(mshta.exe:*)",
      "Bash(mshta:*)",
      "Bash(node:*)",
      "Bash(nox:*)",
      "Bash(osascript:*)",
      "Bash(perl:*)",
      "Bash(powershell.exe:*)",
      "Bash(powershell:*)",
      "Bash(pwsh.exe:*)",
      "Bash(pwsh:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(regsvr32.exe:*)",
      "Bash(regsvr32:*)",
      "Bash(rsync:*)",
      "Bash(ruby:*)",
      "Bash(rundll32.exe:*)",
      "Bash(rundll32:*)",
      "Bash(sh:*)",
      "Bash(sshfs:*)",
      "Bash(terraform:*)",
      "Bash(tflint:*)",
      "Bash(tfsec:*)",
      "Bash(tox:*)",
      "Bash(wscript.exe:*)",
      "Bash(wscript:*)",
      "Bash(xargs:*)",
      "Bash(zsh:*)",
      "PowerShell",
      "PowerShell(*)"
    ]
  }
}