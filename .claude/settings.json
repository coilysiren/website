{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/lockdown-deny.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "coily hook session-start",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(coily docker:*)",
      "Bash(coily ops aws:*)",
      "Bash(coily ops flyctl:*)",
      "Bash(coily ops gcloud:*)",
      "Bash(coily ops gh:*)",
      "Bash(coily ops kubectl:*)",
      "Bash(coily ops mcporter:*)",
      "Bash(coily ops netlify:*)",
      "Bash(coily pkg brew:*)",
      "Bash(coily pkg bun:*)",
      "Bash(coily pkg bundle:*)",
      "Bash(coily pkg cargo:*)",
      "Bash(coily pkg gem:*)",
      "Bash(coily pkg nix:*)",
      "Bash(coily pkg npm:*)",
      "Bash(coily pkg pip:*)",
      "Bash(coily pkg pipx:*)",
      "Bash(coily pkg pnpm:*)",
      "Bash(coily pkg poetry:*)",
      "Bash(coily pkg scoop:*)",
      "Bash(coily pkg uv:*)",
      "Bash(coily pkg yarn:*)",
      "Bash(coily tailscale:*)",
      "Bash(coily:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(yq:*)"
    ],
    "deny": [
      "Bash(git clean -fd:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(ssh:*)"
    ]
  }
}
